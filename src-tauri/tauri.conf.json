{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Uni-HWP",
  "version": "8.1.102",
  "identifier": "org.unihwp.editor",
  "build": {
    "beforeDevCommand": "cmd /c ensure-vite-dev-server.cmd",
    "beforeBuildCommand": "node ./src-tauri/build-frontend.mjs",
    "devUrl": "http://localhost:7710",
    "frontendDist": "../apps/studio/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Uni-HWP",
        "width": 1200,
        "height": 800,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.ico", "icons/icon.png", "icons/icon.icns"],
    "publisher": "Uni-HWP Studio",
    "windows": {
      "wix": {
        "language": ["ko-KR"]
      },
      "nsis": {
        "languages": ["Korean"]
      }
    }
  }
}
