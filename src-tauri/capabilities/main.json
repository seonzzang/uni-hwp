{
  "identifier": "main-capability",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-destroy",
    "core:webview:allow-print",
    "core:event:allow-listen",
    "core:event:allow-emit",
    "fs:allow-read-file",
    "shell:allow-open",
    "dialog:allow-open",
    {
      "identifier": "fs:allow-read-file",
      "allow": [{ "path": "**" }]
    }
  ]
}
